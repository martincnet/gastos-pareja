rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: cualquier autenticado puede leer (necesario para buscar por email al crear grupo)
    // Solo puede escribir su propio documento
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Grupos: solo miembros (o invitados por email) pueden leer
    // Solo el creador puede eliminar; cualquier miembro puede actualizar
    match /grupos/{grupoId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.miembros ||
        request.auth.token.email in resource.data.emailsInvitados
      );
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.miembros &&
        request.auth.uid == request.resource.data.creadoPor;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.miembros;
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.creadoPor;
    }

    // Gastos: solo miembros del grupo pueden leer/crear/eliminar
    // Solo el que cargó el gasto puede editarlo
    // Al crear, cargadoPor debe ser el usuario autenticado
    match /gastos/{gastoId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/grupos/$(resource.data.grupoId)).data.miembros;
      allow create: if request.auth != null &&
        request.resource.data.cargadoPor == request.auth.uid &&
        request.auth.uid in get(/databases/$(database)/documents/grupos/$(request.resource.data.grupoId)).data.miembros;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.cargadoPor;
      allow delete: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/grupos/$(resource.data.grupoId)).data.miembros;
    }

    // FCM Tokens: solo el propio usuario
    match /fcmTokens/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
